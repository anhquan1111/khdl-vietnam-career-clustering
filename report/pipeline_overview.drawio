        <mxCell id="src" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Nguồn dữ liệu&lt;/b&gt;&lt;br&gt;HuggingFace: tinixai/vietnamese-job-descriptions&lt;br&gt;606,878 JD × 14 cột (Parquet ~293 MB)" vertex="1">
          <mxGeometry height="60" width="460" x="220" y="20" as="geometry" />
        </mxCell>
        <mxCell id="s0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Stage 0 — Tải + Split 80/20&lt;/b&gt; (random_state=42)&lt;br&gt;notebooks/_download_and_split.py" vertex="1">
          <mxGeometry height="50" width="460" x="220" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=middle;fontSize=11;spacingLeft=10;" value="&lt;b&gt;Stage 1 — EDA&lt;/b&gt; (01_EDA.ipynb)&lt;br&gt;• Khảo sát phân phối lương, KN, vùng, ngành&lt;br&gt;• Phát hiện sentinel ‘-999tr’, junk bucket years_exp=9&lt;br&gt;• Đề xuất 3 hàm parse" vertex="1">
          <mxGeometry height="80" width="460" x="220" y="310" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=middle;fontSize=11;spacingLeft=10;" value="&lt;b&gt;Stage 2 — Cleaning&lt;/b&gt; (02_Cleaning.ipynb)&lt;br&gt;• Parse expected_salary (4 regex pattern, drop &gt;100tr)&lt;br&gt;• Parse years_exp (rule junk detection: n&lt;500 &amp;amp; pos_missing&gt;0.5)&lt;br&gt;• Parse province (regex 2 lớp: 63 tỉnh + district→HCM/HN)&lt;br&gt;• industries_list multi-label (top-50 ngành + Other)&lt;br&gt;• Chuẩn hoá categorical + text" vertex="1">
          <mxGeometry height="120" width="460" x="220" y="430" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=middle;fontSize=11;spacingLeft=10;" value="&lt;b&gt;Stage 3 — Feature Engineering&lt;/b&gt; (03_Feature_Engineering.ipynb)&lt;br&gt;• Numeric: impute median + StandardScaler → 2 cột&lt;br&gt;• One-hot: 4 cột categorical → 94 cột&lt;br&gt;• Multi-label industries → 51 cột&lt;br&gt;• TF-IDF: job_title (1,2)gram 5k + 3 cột text dài (1,1) 27k&lt;br&gt;→ hstack thành ma trận sparse 32,107 cột" vertex="1">
          <mxGeometry height="110" width="460" x="220" y="690" as="geometry" />
        </mxCell>
        <mxCell id="fe_tr" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontSize=11;" value="&lt;b&gt;X_train.npz&lt;/b&gt; (sparse CSR)&lt;br&gt;459k × 32k, density 0.64%" vertex="1">
          <mxGeometry height="60" width="220" x="180" y="840" as="geometry" />
        </mxCell>
        <mxCell id="fe_te" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontSize=11;" value="&lt;b&gt;X_test.npz&lt;/b&gt; (sparse CSR)&lt;br&gt;115k × 32k" vertex="1">
          <mxGeometry height="60" width="220" x="500" y="840" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=middle;fontSize=11;spacingLeft=10;" value="&lt;b&gt;Stage 4 — Modeling&lt;/b&gt; (04_Modeling.ipynb)&lt;br&gt;Stratified 150k sample (theo ngành đầu) → CV chọn hyperparam&lt;br&gt;• 5-fold cho Ridge (grid α) + Lasso-SGD (grid α)&lt;br&gt;• 3-fold × Optuna 15-trial (TPE + Hyperband) cho LightGBM&lt;br&gt;→ Refit best hyperparam trên FULL train (459k) → evaluate test 1 lần" vertex="1">
          <mxGeometry height="100" width="460" x="220" y="940" as="geometry" />
        </mxCell>
